# =========================

*.pkl

# Ignore parquet files EXCEPT lightweight demo files
*.parquet
!data/processed/events.parquet
!data/processed/bursts.parquet

# Ignore large CSVs
*.CSV

# OPTIONAL
# Uncomment if needed
# *.csv

